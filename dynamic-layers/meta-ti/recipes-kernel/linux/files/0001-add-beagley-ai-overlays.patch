diff --git a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-hdmi-dss0-dpi1.dtso b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-hdmi-dss0-dpi1.dtso
